generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlanTier {
  FREE
  PRO
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  INCOMPLETE
  UNPAID
}

enum LeadStatus {
  NEW
  QUALIFIED
  CONVERTED
  ARCHIVED
}

enum LeadSource {
  CHAT_AGENT
  LANDING_FORM
  MANUAL
  IMPORT
}

enum UsageAction {
  ITINERARY
  AGENT_MESSAGE
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

model User {
  id               String    @id
  email            String    @unique
  firstName        String?
  lastName         String?
  imageUrl         String?
  stripeCustomerId String?   @unique
  planTier         PlanTier  @default(FREE)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  lastSeenAt       DateTime?
  deletedAt        DateTime?

  subscriptions    Subscription[]
  trips            Trip[]
  usageRecords     UsageRecord[]
  conversations    Conversation[]

  @@index([email])
  @@index([stripeCustomerId])
  @@index([planTier])
  @@index([createdAt])
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String
  stripeSubscriptionId String             @unique
  stripeCustomerId     String
  stripePriceId        String?
  status               SubscriptionStatus
  planTier             PlanTier
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean            @default(false)
  canceledAt           DateTime?
  trialEnd             DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, status])
  @@index([stripeCustomerId])
  @@index([currentPeriodEnd])
}

model UsageRecord {
  id        String      @id @default(cuid())
  userId    String
  action    UsageAction
  periodKey String
  metadata  Json?
  createdAt DateTime    @default(now())

  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, action, periodKey])
  @@index([userId, createdAt])
}

model Trip {
  id          String    @id @default(cuid())
  userId      String
  destination String
  startDate   String
  endDate     String
  budget      String
  interests   String
  itinerary   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  user        User?     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, createdAt])
  @@index([deletedAt])
}

model Lead {
  id          String      @id @default(cuid())
  email       String      @unique
  name        String      @default("")
  phone       String      @default("")
  destination String      @default("")
  dates       String      @default("")
  travelers   String      @default("")
  budget      String      @default("")
  interests   String      @default("")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  status      LeadStatus  @default(NEW)
  source      LeadSource  @default(CHAT_AGENT)
  userId      String?

  conversations Conversation[]

  @@index([status])
  @@index([createdAt])
  @@index([userId])
}

model Conversation {
  id        String    @id @default(cuid())
  userId    String?
  leadId    String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  lead      Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  messages  Message[]

  @@index([userId])
  @@index([leadId])
  @@index([createdAt])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  role           MessageRole
  content        String
  createdAt      DateTime     @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([conversationId, createdAt])
}
